---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Onay Akbaş" lang="en">
  <div class="contact-wrap">
    <h2 class="page-title">Contact</h2>
    <p class="email">
      <a href="mailto:akbasonay@gmail.com">akbasonay@gmail.com</a>
    </p>
  </div>
</Layout>

<style>
  .contact-wrap {
    max-width: 480px;
  }

  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 2rem;
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }

  .email a {
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
  }

  .email a:hover { border-color: var(--text); }
</style>
