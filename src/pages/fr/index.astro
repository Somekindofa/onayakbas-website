---
import Layout from '../../layouts/Layout.astro';

const paintings = Array.from({ length: 9 }, (_, i) => ({
  src: `/images/${i + 1}.jpg`,
  alt: `Peinture ${i + 1}`,
}));
---
<Layout title="Onay Akbaş — Peintre" lang="fr">
  <section class="hero">
    <h1>Onay Akbaş</h1>
    <p class="tagline">Peintre</p>
  </section>
  <section class="grid">
    {paintings.map(p => (
      <a href="/fr/work" class="thumb">
        <img src={p.src} alt={p.alt} loading="lazy" />
      </a>
    ))}
  </section>
</Layout>

<style>
  .hero { text-align: center; padding: 4rem 0 3rem; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 300; letter-spacing: 0.08em; }
  .tagline { margin-top: 0.5rem; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
  .thumb { display: block; overflow: hidden; aspect-ratio: 4/3; background: #e8e4dc; }
  .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .thumb:hover img { transform: scale(1.03); }
  @media (max-width: 768px) { .grid { grid-template-columns: repeat(2, 1fr); } }
</style>
